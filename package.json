{
  "name": "yt-shorts-gen",
  "version": "1.0.0",
  "description": "YouTube Shorts video generator using Remotion",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "storybook": "npm run storybook --workspace=packages/storybook",
    "start": "remotion studio",
    "build": "remotion render ShortsComposition out/video.mp4",
    "render": "npx tsx scripts/render-local.ts",
    "gen:audio": "npx tsx elevenlabs/generate.ts",
    "pipeline": "npx tsx pipeline.ts",
    "demo": "npx tsx scripts/render-demo.ts",
    "render:existing": "npx tsx scripts/render-existing.ts"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "4.0.435",
    "@remotion/light-leaks": "4.0.435",
    "@remotion/media": "4.0.435",
    "@remotion/media-utils": "^4.0.0",
    "@remotion/transitions": "4.0.435",
    "dotenv": "^16.0.0",
    "openai": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  }
}
