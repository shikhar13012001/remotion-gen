{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@yt-shorts/core":           ["../core/src/index.ts"],
      "@yt-shorts/video-renderer": ["../video-renderer/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
