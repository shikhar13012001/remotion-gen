{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["src/**/*", "elevenlabs/**/*", "lmstudio/**/*", "scripts/**/*", "pipeline.ts", "pipelineHelpers.ts", "pipelineAudio.ts", "pipelineOutput.ts", "remotion.config.ts"],
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node"
    }
  }
}
