{
  "_comment": "Call 1b output: VisualBrief — director's pre-computed visual plan for the video.",
  "schemaBrief": {
    "type": "object",
    "required": ["visual_theme", "acts", "key_moments", "budget", "rhythm_notes"],
    "additionalProperties": false,
    "properties": {
      "visual_theme": {
        "type": "string",
        "minLength": 10,
        "maxLength": 120
      },
      "acts": {
        "type": "array",
        "minItems": 2,
        "maxItems": 4,
        "items": {
          "type": "object",
          "required": ["label", "sentence_range", "dominant_template", "visual_tone"],
          "additionalProperties": false,
          "properties": {
            "label": {
              "type": "string",
              "minLength": 2,
              "maxLength": 30
            },
            "sentence_range": {
              "type": "array",
              "items": { "type": "integer", "minimum": 1 },
              "minItems": 2,
              "maxItems": 2
            },
            "dominant_template": {
              "type": "string",
              "enum": ["animated_graphic", "fullbleed", "text_dominant", "stat_callout"]
            },
            "visual_tone": {
              "type": "string",
              "minLength": 5,
              "maxLength": 100
            }
          }
        }
      },
      "key_moments": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["sentence_index", "scene_template", "reason"],
          "additionalProperties": false,
          "properties": {
            "sentence_index": {
              "type": "integer",
              "minimum": 1
            },
            "scene_template": {
              "type": "string",
              "enum": ["animated_graphic", "fullbleed", "text_dominant", "stat_callout"]
            },
            "animation_hint": {
              "type": "string",
              "enum": [
                "counter", "timeline", "flow_diagram", "comparison_bars",
                "bar_chart", "line_chart", "percentage_fill", "map_spread",
                "world_highlight", "icon_arrangement", "shape_metaphor"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 5,
              "maxLength": 100
            }
          }
        }
      },
      "budget": {
        "type": "object",
        "required": ["animated_graphic", "stat_callout", "fullbleed", "text_dominant"],
        "additionalProperties": false,
        "properties": {
          "animated_graphic": { "type": "integer", "minimum": 0 },
          "stat_callout":     { "type": "integer", "minimum": 0 },
          "fullbleed":        { "type": "integer", "minimum": 0 },
          "text_dominant":    { "type": "integer", "minimum": 0 }
        }
      },
      "rhythm_notes": {
        "type": "string",
        "minLength": 10,
        "maxLength": 200
      }
    }
  }
}
